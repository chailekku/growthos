APP_NAME="Gekku GrowthOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Bangkok

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=th_TH

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# Database - KKU MySQL Server
# ============================================================
DB_CONNECTION=mysql
DB_HOST=your_kku_mysql_host
DB_PORT=3306
DB_DATABASE=gekku_growthos
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.kku.ac.th
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@kku.ac.th"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# KKU Single Sign On - Microsoft Azure AD
# (Students: @kkumail.com | Staff: @kku.ac.th)
# ============================================================
MICROSOFT_CLIENT_ID=your_azure_client_id
MICROSOFT_CLIENT_SECRET=your_azure_client_secret
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT=your_kku_tenant_id

# Google OAuth (สำหรับอาจารย์ภายนอกที่ไม่มีอีเมล @kku.ac.th)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ============================================================
# KKU Email Domain Configuration
# ============================================================
KKU_STUDENT_DOMAIN=kkumail.com
KKU_STAFF_DOMAIN=kku.ac.th

# ============================================================
# AI Configuration
# ============================================================
OPENAI_API_KEY=your_openai_key
OPENAI_ORGANIZATION=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_MAX_TOKENS=600
DEMO_MODE=true

VITE_APP_NAME="${APP_NAME}"
